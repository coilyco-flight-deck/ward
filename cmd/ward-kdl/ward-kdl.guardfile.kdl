wrap ward-kdl ops forgejo {
    spec forgejo.swagger.v1.json
    base-url "forgejo.coilysiren.me/api/v1"
    auth header-token {
        header Authorization
        prefix "token "
        ssm "/forgejo/api-token"
    }

    can read orgs
    can list orgs
    can create orgs
    can delete orgs

    // labels and milestones: all-scalar bodies, pure expansion-table rows.
    can read labels
    can list labels
    can create labels
    can edit labels
    can delete labels

    can read milestones
    can list milestones
    can create milestones
    can edit milestones
    can delete milestones

    // issues: the array-body + query-param batch; close/reopen are
    // fixed-body toggles, delete is the only destructive leaf.
    can create issues
    can list issues
    can view issues
    can edit issues
    can comment issues
    can close issues
    can reopen issues
    can delete issues

    // releases: all-scalar; upload-asset (multipart) is a named follow-up.
    can read releases
    can list releases
    can create releases
    can edit releases
    can delete releases

    // repos, second batch: search-list, sparse edit (nested objects ride
    // --body-file), fork, and the archive/unarchive boolean toggles.
    can list repos
    can edit repos
    can fork repos
    can archive repos
    can unarchive repos

    // pulls stay read-only: pr create is policy-disabled (merge to main).
    can read pulls
    can list pulls

    // actions tasks: the CI-run read surface.
    can list tasks
}
