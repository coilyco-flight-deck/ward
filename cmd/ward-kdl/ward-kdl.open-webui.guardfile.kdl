// Open WebUI ops surface for ward-kdl, driving the vendored open-webui.openapi.json
// (OpenAPI 3.1, JSON). The target is the tailnet-only chat front-end for the tower's
// Qwen (deploy surface coilyco-bridge/deploy services/open-webui). Ops are pinned
// explicitly because Open WebUI's operationIds don't follow the verb+resource
// convention. See ../../docs/ward-kdl.open-webui.guardfile.md.
//
// Two SSM prerequisites (both resolved at request time, never committed - the ward
// repo is public-mirrored and the tailnet FQDN is opaque):
//   /coilysiren/open-webui/url      - the host, e.g. open-webui.<tailnet>.ts.net
//   /coilysiren/open-webui/api-key  - a Bearer API key minted in the UI
//                                     (Settings -> Account) or via POST
//                                     /api/v1/auths/api_key, then put to SSM.
wrap ward-kdl ops open-webui {
    spec open-webui.openapi.json
    base-url {
        ssm "/coilysiren/open-webui/url"
    }
    auth bearer {
        ssm "/coilysiren/open-webui/api-key"
    }
    // auths: whoami only. Cheapest call to validate the token. Signin/signup/api-key
    // management and all admin config are not exposed through ward.
    can get session {
        op get_session_user_api_v1_auths__get
    }
    // models: the UI-layer model list (what the chat dropdown shows), read-only.
    can list models {
        op get_models_api_v1_models_list_get
    }
    // completions: the point of the surface - send a chat completion to Qwen through
    // Open WebUI's model layer (OpenAI-shaped body, `model` from `list models`).
    can create completion {
        op chat_completion_api_chat_completions_post
    }
    // ollama: direct passthrough to the tower's Ollama. Reads plus generate/chat/pull.
    // Model deletion is intentionally NOT exposed (irreversible, human-only on the box).
    can get ollama-status {
        op get_status_ollama__get
    }
    can list ollama-models {
        op get_ollama_tags_ollama_api_tags_get
    }
    can list ollama-loaded {
        op get_ollama_loaded_models_ollama_api_ps_get
    }
    can show ollama-model {
        op show_model_info_ollama_api_show_post
    }
    can generate ollama {
        op generate_completion_ollama_api_generate_post
    }
    can chat ollama {
        op generate_chat_completion_ollama_api_chat_post
    }
    can pull ollama-model {
        op pull_model_ollama_api_pull_post
    }
    // chats: saved-conversation CRUD. delete-all (DELETE /api/v1/chats/) is intentionally
    // NOT exposed - it wipes every chat in one call.
    can list chats {
        op get_session_user_chat_list_api_v1_chats_list_get
    }
    can search chats {
        op search_user_chats_api_v1_chats_search_get
    }
    can get chat {
        op get_chat_by_id_api_v1_chats__id__get
    }
    can create chat {
        op create_new_chat_api_v1_chats_new_post
    }
    can delete chat {
        op delete_chat_by_id_api_v1_chats__id__delete
    }
    // configs: read-only export of the server config (admin token required).
    can export config {
        op export_config_api_v1_configs_export_get
    }
}
