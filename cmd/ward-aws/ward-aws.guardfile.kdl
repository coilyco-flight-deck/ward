// The aws CLI surface as exec-dialect policy (cli-guard execverb).
// One open-passthrough grant keeps the funnel comprehensive - any service or
// operation routes through ward - while a `deny-when` guard spells the read
// gate out in the guardfile itself: read-only verbs (get-/list-/describe-, the
// aws CLI's own naming convention) naming a sensitive resource are denied
// pre-send. The selector + globs read like the invocation you'd type, not an
// opaque gate name - the resource set (secrets / credentials / tfstate /
// backups / admin+root role ARNs) is visible here instead of baked in Go.
// `any-arg` scans every positional; WARD_AWS_ALLOW_SENSITIVE_READ is the
// one-shot escape for a deliberate read.
wrap ward ops aws {
    exec aws

    can run "*" {
        deny-when any-arg matches \
            "*secret*" "*credential*" "*-private*" "*private-*" \
            "*tfstate*" "*terraform-state*" "*-backup*" "*-backups*" \
            "arn:aws:iam::*:role/*admin*" "arn:aws:iam::*:role/*root*" \
        {
            only-reads
            allow-env "WARD_AWS_ALLOW_SENSITIVE_READ"
        }
        describe "open aws passthrough; sensitive reads denied pre-send"
    }
}
