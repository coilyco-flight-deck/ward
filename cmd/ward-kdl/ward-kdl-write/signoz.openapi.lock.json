    "/api/v3/query_range": {
      "post": {
        "description": "Execute a query against traces, logs, or metrics over a time range. A POST that reads telemetry; nothing is created or mutated.",
        "operationId": "queryRange",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "properties": {
                  "compositeQuery": {
                    "description": "the builder/clickhouse/promql query tree; supply via --body-file",
                    "type": "object"
                  },
                  "end": {
                    "description": "range end, epoch milliseconds",
                    "type": "integer"
                  },
                  "start": {
                    "description": "range start, epoch milliseconds",
                    "type": "integer"
                  },
                  "step": {
                    "description": "step interval in seconds",
                    "type": "integer"
                  }
                },
                "required": [
                  "start",
                  "end"
                ],
                "type": "object"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {}
              }
            },
            "description": "query result"
          },
          "400": {
            "content": {
              "application/json": {
                "schema": {}
              }
            },
            "description": "bad query"
          }
        },
        "summary": "Run a v3 range query",
        "tags": [
          "Query"
        ]
      }
