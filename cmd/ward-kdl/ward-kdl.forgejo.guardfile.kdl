// Forgejo ops surface for ward-kdl. Every `can` resolves its operationId by
// convention (verb + resource -> method + path); the only explicit `op` pins are
// on the repo-label denials below, where a bare `label` would resolve org-ward.
// Hardened per ward#109: orgs and repos lose their irreversible verbs, repo-label
// CRUD moves to org-labels, a cross-repo issue search and a move-issue action
// land, and every path-{owner} leaf is scoped to coily* owners. Repo-level label
// create/edit are additionally policy-disabled per ward#107 (dup P0-P4 prevention).
// Auto-resolution per cli-guard#147. See
// ../../docs/ward-kdl/ward-kdl.forgejo.guardfile.md.
wrap ward-kdl ops forgejo {
    spec forgejo.swagger.v1.json
    base-url "forgejo.coilysiren.me/api/v1"
    // Auth as the coilyco-ops bot, not a personal PAT (ward#151), so automated
    // ops attribute to the bot. Token + scopes: provision-coilyco-ops-bot.sh.
    auth header-token {
        header Authorization
        prefix "token "
        value ssm "/forgejo/coilyco-ops/api-token"
    }
    // Scope gate: every leaf whose path carries {owner} must name a coily* owner.
    restrict owner matches coily*
    // repos: read/create/edit/delete plus the cross-repo `search` finder. Fork
    // and archive/unarchive are denied below as human-only irreversible toggles.
    can get repo
    can search repo {
        describe "cross-repo repo finder (GET /repos/search)"
    }
    can create repo
    can edit repo
    can delete repo {
        describe "irreversible: deletes the repo and all its data"
    }
    never fork repo {
        message "forking is a human-only operation; fork in the web UI"
    }
    never archive repo {
        message "archive/unarchive flips a repo's lifecycle; do it in the web UI"
    }
    never unarchive repo {
        message "archive/unarchive flips a repo's lifecycle; do it in the web UI"
    }
    // orgs: read-only. Org create and delete are human-only.
    can get org
    can list org
    never create org {
        message "org creation is a human-only operation"
    }
    never delete org {
        message "org deletion is irreversible and human-only"
    }
    can create org-repo {
        op createOrgRepo
        describe "create a repo inside an existing org (POST /orgs/{org}/repos); the org-scoped sibling of `create repo` (which targets /user/repos, a path the bot lacks write:user for). The coilyco-ops token already carries write:organization, so this is a missing verb, not a missing scope (ward#218). op pinned because a bare `create org-repo` also matches the deprecated alias. Org create/delete stay human-only; this creates repos within an org, not orgs themselves."
    }
    can list org-repo {
        op orgListRepos
        describe "list the repos an org owns (GET /orgs/{org}/repos). The route survey (ward#92) catalogs each primary org's repos through this leaf; `user-repo list` covers the one primary owner that is a user, not an org."
    }
    can list user-repo {
        op userListRepos
        describe "list the repos a user owns (GET /users/{username}/repos). coilysiren is a user, not an org, so the route survey reaches its repos here rather than through `org-repo list`. Read-only, the survey's other half."
    }
    // search finders: global read-only finders keyed on a query string, with no
    // {owner}/{org} path param to gate - server-wide reads, no new behavior (ward#368).
    can search user {
        describe "user finder (GET /users/search)"
    }
    can search topic {
        describe "topic finder (GET /topics/search)"
    }
    // org-labels: org-level labels (/orgs/{org}/labels); the `org` ancestor scopes
    // them away from repo labels. Issue-label attach/set/remove stays below.
    can get org-label
    can list org-label
    can create org-label
    can edit org-label
    can delete org-label
    // org-members: the org membership roster (GET /orgs/{org}/members); the `org`
    // ancestor scopes it like the org-label/org-repo siblings. Read-only (ward#368).
    can list org-member {
        describe "org member list (GET /orgs/{org}/members)"
    }
    // repo-labels: repo-scoped label create/edit are policy-disabled (ward#107);
    // mint/rename via org-label above, attach via issue-label below. op pinned.
    never create label {
        op issueCreateLabel
        describe "op pinned because a bare `label` resource otherwise resolves to the shallower org path. A repo-level label (POST/PATCH /repos/{owner}/{repo}/labels) that duplicates an org label silently shadows it; that path minted the off-palette dup P0-P4 labels across 26 repos (340 tags re-pointed, 67 labels deleted - coilyco-bridge/coily#248)."
        message "repo-level label create is policy-disabled (ward#107): it mints labels that duplicate and shadow the org P0-P4 taxonomy. Create org labels with `create org-label`."
    }
    never edit label {
        op issueEditLabel
        message "repo-level label edit is policy-disabled (ward#107): edit the org taxonomy with `edit org-label`."
    }
    // milestones: all-scalar CRUD plus the close/reopen fixed-body toggles (the
    // toggles resolve like edit and carry only `body`).
    can get milestone
    can list milestone
    can create milestone
    can edit milestone
    can delete milestone
    can close milestone {
        body state=closed
    }
    can reopen milestone {
        body state=open
    }
    // issues: the array-body + query-param group. close/reopen are fixed-body
    // toggles; delete is denied (close instead); search is the cross-repo finder.
    can get issue
    can view issue
    can list issue
    action list-all issue {
        describe "List all issues by auto-paginating issue list."
        input owner {
            positional
            required
            help "repo owner"
        }
        input repo {
            positional
            required
            help "repo name"
        }
        input state {
            flag
            help "whether issue is open or closed"
        }
        input labels {
            flag
            help "comma separated list of labels"
        }
        input q {
            flag
            help "search string"
        }
        input type {
            flag
            help "filter by type (issues / pulls)"
        }
        input milestones {
            flag
            help "comma separated list of milestone names or ids"
        }
        input since {
            flag
            help "Only show items updated after the given RFC3339 time"
        }
        input before {
            flag
            help "Only show items updated before the given RFC3339 time"
        }
        input created_by {
            flag
            help "Only show items created by the given user"
        }
        input assigned_by {
            flag
            help "Only show items assigned by the given user"
        }
        input mentioned_by {
            flag
            help "Only show items mentioning the given user"
        }
        input limit {
            flag
            help "page size of results"
        }
        input sort {
            flag
            help "Type of sort"
        }
        collect list issue {
            args {
                owner $owner
                repo $repo
                state $state
                labels $labels
                q $q
                type $type
                milestones $milestones
                since $since
                before $before
                created_by $created_by
                assigned_by $assigned_by
                mentioned_by $mentioned_by
                sort $sort
            }
            page-param page
            limit-param limit
            limit $limit
            default-limit "50"
            as issues
        }
    }
    can search issue
    can create issue
    can edit issue
    can comment issue
    can close issue {
        body state=closed
    }
    can reopen issue {
        body state=open
    }
    never delete issue {
        message "issue deletion is irreversible; close it instead (move-issue does this)"
    }
    can list issue-comment {
        op issueGetComments
        describe "the comments sub-collection GET, pinned by op (the convention resolves `list issue-comment` against issueGetComments poorly). The `view issue` shadow action below chains this so a view returns the thread."
    }
    // repo refs: read-only list sub-collections (commits/branches/tags), each
    // {owner}-scoped by the coily* gate above; native GETs, no new behavior (ward#368).
    can list commit {
        op repoGetAllCommits
        describe "commit list (GET /repos/{owner}/{repo}/commits). op pinned because the operationId is repoGetAllCommits - a `get`-shaped id the `list commit` convention does not reach."
    }
    can list branch {
        op repoListBranches
        describe "branch list (GET /repos/{owner}/{repo}/branches). op pinned because a bare `list branch` otherwise resolves to repoListBranchProtection (GET .../branch_protections), the shallower branch-prefixed match."
    }
    can list tag {
        describe "tag list (GET /repos/{owner}/{repo}/tags)"
    }
    // releases, with the multipart asset upload beside them (upload-asset resolves
    // as create-on the assets sub-collection).
    can get release
    can list release
    can create release
    can edit release
    can delete release
    can upload-asset release
    // pulls: not surfaced through ward. Read them in the Forgejo web UI.
    never view pr {
        message "pull requests are not exposed through ward; read them in the web UI"
    }
    never list pr {
        message "pull requests are not exposed through ward; read them in the web UI"
    }
    // issue-labels: the compound resource targets the issue's labels sub-collection;
    // add/set/remove are the membership verbs (POST/PUT/DELETE).
    can list issue-label
    can add issue-label
    can set issue-label
    can remove issue-label
    // actions tasks: the CI-run read surface, plus the ci-watch poll action.
    can list tasks
    // ci-watch: poll `list tasks` until every job of one run reaches a terminal
    // state, then exit non-zero if any failed. JMESPath; `$run` binds from --run.
    action ci-watch {
        describe "Watch a CI run to completion, then surface failing-job status."
        input repo {
            positional
            required
            help "owner/name"
        }
        input run {
            flag
            help "run number"
        }
        poll list tasks {
            args {
                owner-repo $repo
            }
            until "length(workflow_runs[?run_number==$run && status!='success'\n        && status!='failure' && status!='cancelled'\n        && status!='skipped']) == `0`"
            every "10s"
            timeout "30m"
            as run_tasks
        }
        fail-when "length($run_tasks.workflow_runs[?run_number==$run && status=='failure']) > `0`"
    }
    // move-issue: copy title/body to a target repo, back-link, then CLOSE the
    // source (never delete). Carrying labels/milestone is deferred (array flow).
    action move-issue {
        describe "Move an issue to another repo (copy title/body, back-link, close source). Never deletes."
        input source {
            positional
            required
            help "source owner/name"
        }
        input index {
            positional
            required
            help "source issue number"
        }
        input target {
            positional
            required
            help "target owner/name"
        }
        call view issue {
            args {
                owner-repo $source
                index $index
            }
            as src
        }
        call create issue {
            args {
                owner-repo $target
                title $src.title
                body $src.body
            }
            as dst
        }
        call comment issue {
            args {
                owner-repo $source
                index $index
                body $dst.html_url
            }
        }
        call close issue {
            args {
                owner-repo $source
                index $index
            }
        }
    }
    // view issue: shadow the generated `issue view` leaf so a view returns the
    // issue AND its comment thread (ward#170). See describe for the ward#225 note.
    action view issue {
        describe "View an issue with its full comment thread (issue + comments). Shadows the generated `issue view` (same 3-arg signature) so a view never misses the comments - the ward#170 failure mode where an agent reads the body and skips the thread. ward#225: ward's CLI renders this through a lean projection that collapses every commenter to its login literal, so a multi-comment issue no longer repeats each commenter's full profile once per comment; the guardfile shape is unchanged."
        input owner {
            positional
            required
            help "repo owner"
        }
        input repo {
            positional
            required
            help "repo name"
        }
        input index {
            positional
            required
            help "issue number"
        }
        call view issue {
            args {
                owner $owner
                repo $repo
                index $index
            }
            as issue
        }
        call list issue-comment {
            args {
                owner $owner
                repo $repo
                index $index
            }
            as comments
        }
    }
    // comment issue: shadow the leaf so a comment on a CLOSED issue warns instead
    // of posting silently - get-then-comment with a fail-when over state (ward#380).
    action comment issue {
        describe "Post a comment on an issue, warning when the issue is closed (ward#380). Shadows the generated `issue comment` leaf (same 3-arg + --body signature): it GETs the issue to read its state, posts the comment, then `fail-when`s on state=='closed' so commenting on a closed issue exits non-zero instead of passing silently. The comment IS still created - the non-zero exit and the issue body in the output are the warning that the target was closed, not a block on the post. Renders {comment, issue} together like every mount call action."
        input owner {
            positional
            required
            help "repo owner"
        }
        input repo {
            positional
            required
            help "repo name"
        }
        input index {
            positional
            required
            help "issue number"
        }
        input body {
            flag
            required
            help "The body of the comment"
        }
        call get issue {
            args {
                owner $owner
                repo $repo
                index $index
            }
            as issue
        }
        call comment issue {
            args {
                owner $owner
                repo $repo
                index $index
                body $body
            }
            as comment
        }
        fail-when "$issue.state == 'closed'"
    }
}
