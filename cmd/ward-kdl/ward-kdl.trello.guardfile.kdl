// Trello ops surface for ward-kdl, driving the vendored trello.openapi.json
// (OpenAPI 3.0). Trello carries mutation payloads in `in:query` params, so the
// create/edit fields mount as flags, not a JSON body. Auth is the dual-secret
// query-param scheme (?key=&token=). Every `can` resolves by convention, no
// explicit op (cli-guard#147). See ../../docs/ward-kdl.trello.guardfile.md.
wrap ward-kdl ops trello {
    spec trello.openapi.json
    base-url "api.trello.com/1"
    auth query-param {
        param key { ssm "/trello/api-key" }
        param token { ssm "/trello/api-token" }
    }

    // No restrict clause: Trello path params are opaque board/card/list ids with
    // no scopeable shape (unlike Forgejo's {owner}), so a glob gate is meaningless.

    // boards: read/create/edit, plus the lists/cards a board holds. Board deletion
    // is denied. list-lists/list-cards read the board's sub-collections.
    can get board
    can create board
    can edit board
    can list-lists board
    can list-cards board
    never delete board { message "board deletion is irreversible; delete it in the Trello UI" }

    // lists: read and create (standalone, and onto a board via create-on-board).
    can get list
    can create list
    can create-on-board list

    // cards: full read/create/edit/delete plus the comment action (comment posts
    // the card's comments sub-collection).
    can get card
    can create card
    can edit card
    can delete card
    can comment card
}
