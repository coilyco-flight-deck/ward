{
  "hooks": {
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "ward hook pre-tool-use",
            "type": "command"
          }
        ],
        "matcher": "Bash"
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(cat:*)",
      "Bash(file:*)",
      "Bash(find:*)",
      "Bash(git:*)",
      "Bash(grep:*)",
      "Bash(head:*)",
      "Bash(jq:*)",
      "Bash(ls:*)",
      "Bash(rg:*)",
      "Bash(stat:*)",
      "Bash(tail:*)",
      "Bash(tree:*)",
      "Bash(ward:*)",
      "Bash(ward-kdl:*)",
      "Bash(wc:*)",
      "Bash(yq:*)"
    ],
    "deny": [
      "Bash(flyctl:*)",
      "Bash(gcloud:*)",
      "Bash(git clean -fd:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)",
      "Bash(mcporter:*)",
      "Bash(ssh:*)",
      "Read(/Users/kai/projects/coilysiren/coilyco-vault/**)",
      "Read(~/projects/coilysiren/coilyco-vault/**)"
    ]
  }
}
