// SigNoz WRITE tier - the middle of the read ⊂ write ⊂ admin chain (ward#338).
// `inherit` (cli-guard#160) pulls in every read-tier grant (and its
// spec/base-url/auth singletons, which this file does not restate), then layers
// the authoring verbs on top: create/edit over dashboards and rules, plus the two
// append-only `create` leaves signoz exposes (the log-pipeline apply and the
// query-range read-POST). The result is a `ward-kdl-write` binary that can author
// content but never delete it - no delete leaf is compiled in at any tier.
//
// Tier-placement note - `create query-range` is the instructive edge case
// (ward#338): /api/v3/query_range is a POST that *reads* telemetry (nothing is
// created), so semantically it is a read, but cli-guard compiles it from a
// `create` verb. Tier placement follows the verb it compiles to, not the HTTP
// semantics, so it lands in write beside the other `create` leaves rather than in
// read. The describe text already flags the read-not-write semantics for callers;
// this is the documented schema other tiered areas reference.
//
// The two `never delete` denials live here, with their verb family, and inherit
// up to admin, so deletion stays denied and effective at both authoring tiers
// (ward#241). They are belt-and-suspenders: the spec models no delete path, so no
// delete leaf compiles into any tier regardless.
//
// `restrict` does not inherit (cli-guard#160), but signoz has no owner/scope gate
// to re-declare (it carries none in the monolith either). See
// ../../../docs/ward-kdl/ward-kdl.signoz.write.guardfile.md.
wrap ward-kdl-write ops signoz {
    inherit "../ward-kdl-read/ward-kdl.signoz.read.guardfile.kdl"
    // query-range: a POST that READS telemetry; op pinned (not CRUD-shaped). In
    // write because it compiles from `create`, not because it mutates (see header).
    can create query-range {
        op queryRange
        describe "execute a v3 range query (POST /api/v3/query_range). A POST that READS telemetry - nothing is created. Supply the builder/clickhouse/promql tree via --body-file; --start/--end (epoch ms) and --step are convenience flags."
    }
    // log pipelines: apply a new version. Versioned server-side, so this is
    // append-only - rollback re-applies a prior set, there is no delete.
    can create pipeline {
        op createPipeline
        describe "apply a new log-pipeline version (POST /api/v1/logs/pipelines). Versioned server-side, so this is append-only: rollback is re-applying a prior set, never a delete. Supply the full set via --body-file."
    }
    // dashboards: add create/edit on top of the inherited read pair.
    can create dashboard {
        describe "create a dashboard (POST /api/v1/dashboards). Supply the JSON document via --body-file; --title/--description/--tags lower to flags."
    }
    can edit dashboard {
        describe "replace a dashboard by uuid (PUT /api/v1/dashboards/{uuid}). Supply the JSON document via --body-file."
    }
    // alert rules: add create/edit on top of the inherited read pair.
    can create rule {
        describe "create an alert rule (POST /api/v1/rules). Supply the JSON document via --body-file; --alert/--ruleType/--alertType/--evalWindow/--frequency lower to flags."
    }
    can edit rule {
        describe "replace an alert rule by id (PUT /api/v1/rules/{id}). Supply the JSON document via --body-file."
    }
    // Curated `never delete` denials (see header): they sit here and inherit up to
    // admin, keeping deletion denied and effective at both authoring tiers.
    never delete dashboard {
        message "dashboard deletion is irreversible (drops the dashboard and all its panels); do it in the SigNoz UI. ward exposes create/read/update only (ward#241)."
    }
    never delete rule {
        message "alert-rule deletion is irreversible; do it in the SigNoz UI. ward exposes create/read/update only, and the enable/disable toggle is deliberately not surfaced (ward#241)."
    }
}
