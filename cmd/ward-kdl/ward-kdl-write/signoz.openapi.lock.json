                    "type": "array"
                  },
                  "tags": {
                    "description": "dashboard tags",
                    "items": {
                      "type": "string"
                    },
                    "type": "array"
                  },
                  "title": {
                    "description": "dashboard title",
                    "type": "string"
                  },
                  "variables": {
                    "description": "template variables; via --body-file",
                    "type": "object"
                  },
                  "widgets": {
                    "description": "panel widgets; via --body-file",
                    "items": {},
                    "type": "array"
                  }
                },
                "type": "object"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {}
              }
            },
            "description": "created"
          }
        },
        "summary": "Create a dashboard",
        "tags": [
          "Dashboards"
        ]
      }
    },
