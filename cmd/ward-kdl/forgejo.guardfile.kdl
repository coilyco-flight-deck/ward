// Proving-slice Guardfile for the temporary ward-kdl CLI: the forgejo org
// read/list/create/delete set. Orgs are the safe by-hand fixture - orgDelete is
// interlocked server-side (refuses while the org owns repos), so the dangerous
// case is unreachable. Sentences resolve through specverb's expansion table
// (deny-by-default). base-url omits the scheme; the engine defaults https://.
wrap ward-kdl ops forgejo {
    spec forgejo.swagger.v1.json
    base-url "forgejo.coilysiren.me/api/v1"
    auth header-token {
        header Authorization
        prefix "token "
        ssm "/forgejo/api-token"
    }

    can read orgs
    can list orgs
    can create orgs
    can delete orgs
}
