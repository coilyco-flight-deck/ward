wrap ward-kdl ops forgejo {
    spec forgejo.swagger.v1.json
    base-url "forgejo.coilysiren.me/api/v1"
    auth header-token {
        header Authorization
        prefix "token "
        ssm "/forgejo/api-token"
    }

    can read orgs
    can list orgs
    can create orgs
    can delete orgs

    // labels and milestones: all-scalar bodies, pure expansion-table rows.
    can read labels
    can list labels
    can create labels
    can edit labels
    can delete labels

    can read milestones
    can list milestones
    can create milestones
    can edit milestones
    can delete milestones

    // issues: the array-body + query-param batch; close/reopen are
    // fixed-body toggles, delete is the only destructive leaf.
    can create issues
    can list issues
    can view issues
    can edit issues
    can comment issues
    can close issues
    can reopen issues
    can delete issues

    // releases: all-scalar; upload-asset (multipart) is a named follow-up.
    can read releases
    can list releases
    can create releases
    can edit releases
    can delete releases

    // repos, second batch: search-list, sparse edit (nested objects ride
    // --body-file), fork, and the archive/unarchive boolean toggles.
    can list repos
    can edit repos
    can fork repos
    can archive repos
    can unarchive repos

    // pulls stay read-only: pr create is policy-disabled (merge to main).
    can read pulls
    can list pulls

    // actions tasks: the CI-run read surface.
    can list tasks

    // ci-watch: the first complex action - poll the granted `list tasks` leaf
    // until every job of one run reaches a terminal state, then exit non-zero
    // if any failed. Replaces the poll loop in scripts/watch-ci.sh; the
    // log-tail half stays in the script until a logs leaf lands (gitea#35176).
    //
    // `until` and `fail-when` are JMESPath, Community Edition (jmespath.site),
    // evaluated against the polled response as the root. A `$name` is a bound
    // input or `as` capture, supplied through the Community Edition's variable
    // scope - baseline JMESPath (jmespath.org) has no `$variable` syntax, so
    // these conditions are not portable to an original-spec evaluator.
    //
    // ListActionTasks returns the ActionTaskResponse wrapper
    // ({total_count, workflow_runs:[...]}), not a bare array, so both
    // conditions project `workflow_runs` first. Terminal states are
    // success/failure/cancelled/skipped; anything else (unknown/waiting/
    // running/blocked) keeps the loop going. `$run` binds only when --run is
    // supplied; omitted, the condition naming it fails closed rather than
    // looping on a null (latest-run defaulting is deferred - see ward#90).
    action ci-watch {
        describe "Watch a CI run to completion, then surface failing-job status."
        input repo { positional; required; help "owner/name" }
        input run  { flag; help "run number" }
        poll list tasks {
            args { owner-repo $repo }
            until """
                length(workflow_runs[?run_number==$run && status!='success'
                        && status!='failure' && status!='cancelled'
                        && status!='skipped']) == `0`
                """
            every   "10s"
            timeout "30m"
            as run_tasks
        }
        // Filter failures to $run too: the listing window can hold terminal
        // tasks from earlier runs, and an unfiltered match would fail spuriously.
        fail-when "length($run_tasks.workflow_runs[?run_number==$run && status=='failure']) > `0`"
    }

    // issue-labels: the API takes names or ids directly, no pre-flight.
    can list issue-labels
    can add issue-labels
    can set issue-labels
    can remove issue-labels

    // release assets: the multipart upload shape.
    can upload release-assets
}
